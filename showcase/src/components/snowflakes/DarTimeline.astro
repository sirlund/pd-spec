---
/**
 * D→A→R timeline bar for visualization slides.
 * `active` determines which dot is highlighted: 'd', 'a', or 'r'.
 * `connector` determines where the V-arrow points: 'left', 'center', or 'right'.
 *
 * Visual state controlled via CSS classes + data attributes:
 *   .dar-label[data-stage]   — stage color on text
 *   .dar-dot[data-stage]     — stage color on dot
 *   .dar-dot--active/--dim   — glow vs hollow
 *   .dar-gradient[data-active] — gradient line variant
 *   .dar-connector           — horizontal connector line
 */
interface Props {
  active: 'd' | 'a' | 'r';
  connector?: 'left' | 'center' | 'right';
}

const { active, connector = active === 'd' ? 'left' : active === 'a' ? 'center' : 'right' } = Astro.props;

const connectorCss = connector === 'left'
  ? 'left: 0; width: 14px;'
  : connector === 'center'
  ? `left: 0; right: calc(50% + 15px);`
  : 'left: 0; right: 46px;';

const arrowPos = connector === 'left'
  ? 'left: 14px;'
  : connector === 'center'
  ? 'left: calc(50% - 15px);'
  : 'right: 14px;';

const afterCss = connector === 'left'
  ? 'left: 46px; right: 0;'
  : connector === 'center'
  ? `left: calc(50% + 15px); right: 0;`
  : 'right: 0; width: 14px;';
---

<div class="col-12" style="padding: 0 20px; margin-bottom: 0;">
  <div style="display: flex; margin-bottom: 8px;">
    <div style="flex: 1;">
      <span class:list={['dar-label', { 'dar-label--dim': active !== 'd' }]} data-stage="d">
        <i class="fa-solid fa-satellite-dish" style="font-size: 20px; margin-right: 5px;"></i> Detección
      </span>
    </div>
    <div style="flex: 1; text-align: center;">
      <span class:list={['dar-label', { 'dar-label--dim': active !== 'a' }]} data-stage="a">
        <i class="fa-solid fa-magnifying-glass-chart" style="font-size: 20px; margin-right: 5px;"></i> Análisis
      </span>
    </div>
    <div style="flex: 1; text-align: right;">
      <span class:list={['dar-label', { 'dar-label--dim': active !== 'r' }]} data-stage="r">
        <i class="fa-solid fa-route" style="font-size: 20px; margin-right: 5px;"></i> Recomendación
      </span>
    </div>
  </div>
  <div style="position: relative; height: 16px;">
    <div class="dar-gradient" data-active={active}></div>
    <div class:list={['dar-dot', active === 'd' ? 'dar-dot--active' : 'dar-dot--dim']} data-stage="d" style="left: 0;"></div>
    <div class:list={['dar-dot', active === 'a' ? 'dar-dot--active' : 'dar-dot--dim']} data-stage="a" style="left: 50%; transform: translateX(-50%);"></div>
    <div class:list={['dar-dot', active === 'r' ? 'dar-dot--active' : 'dar-dot--dim']} data-stage="r" style="right: 0;"></div>
  </div>
</div>

<!-- Bubble connector -->
<div class="col-12" style="height: 22px; position: relative; overflow: visible;">
  <div class="dar-connector" style={`position: absolute; bottom: 0; ${connectorCss}`}></div>
  <svg style={`position: absolute; bottom: 0; ${arrowPos}`} width="30" height="18" viewBox="0 0 30 18" fill="none" overflow="visible">
    <path class="dar-connector-arrow" d="M 0 18 L 15 3 L 30 18" stroke-width="1.5" fill="var(--bg-color)" />
  </svg>
  <div class="dar-connector" style={`position: absolute; bottom: 0; ${afterCss}`}></div>
</div>
