---
/**
 * Dynamic deck route — renders slides from a named subdirectory.
 * A slide at `slides/v2-boceto/01-cover.mdx` is served at `/v2-boceto`.
 */
import PresentationLayout from '../layouts/PresentationLayout.astro';
import theme from '../theme.config';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allSlides = await getCollection('slides');
  const decks = [...new Set(
    allSlides
      .filter(s => s.id.includes('/'))
      .map(s => s.id.split('/')[0])
  )];
  return decks.map(deck => ({ params: { deck } }));
}

const { deck } = Astro.params;
const allSlides = await getCollection('slides');
const slides = allSlides
  .filter(s => s.id.startsWith(`${deck}/`) && !s.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  slides.map(async (slide) => {
    const { Content } = await render(slide);
    return { slide, Content };
  })
);
---

<PresentationLayout title={theme.title}>
  {rendered.map(({ Content }) => (
    <Content />
  ))}
</PresentationLayout>
