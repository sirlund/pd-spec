---
/**
 * Main presentation page — loads slides from content collection.
 * Multi-deck aware: prefers slides in `main/` subdirectory,
 * falls back to flat slides (no subdirectory) for backward compat.
 */
import PresentationLayout from '../layouts/PresentationLayout.astro';
import theme from '../theme.config';
import { getCollection, render } from 'astro:content';

const allSlides = await getCollection('slides');
const mainSlides = allSlides.filter(s => s.id.includes('/') && s.id.startsWith('main/'));
const flatSlides = allSlides.filter(s => !s.id.includes('/'));
const slides = (mainSlides.length > 0 ? mainSlides : flatSlides)
  .filter(s => !s.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  slides.map(async (slide) => {
    const { Content } = await render(slide);
    return { slide, Content };
  })
);
---

<PresentationLayout title={theme.title}>
  {rendered.map(({ Content }) => (
    <Content />
  ))}
  <script is:inline define:vars={{ slugs: slides.map(s => s.id.split('/').pop()) }}>
    window.__slideSlugs = slugs;
  </script>
</PresentationLayout>
