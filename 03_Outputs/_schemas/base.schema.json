{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "base.schema.json",
  "description": "PD-Spec shared schema definitions for all output JSON data",
  "type": "object",
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["type", "version", "generated", "language", "project"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["prd", "report", "presentation", "status", "audit", "strategy"]
        },
        "version": {
          "type": "string",
          "pattern": "^v\\d+\\.\\d+$",
          "description": "Document version (e.g. v1.0, v1.2)"
        },
        "generated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Generation date in YYYY-MM-DD format"
        },
        "language": {
          "type": "string",
          "minLength": 2,
          "maxLength": 5,
          "description": "Output language code (e.g. en, es)"
        },
        "project": {
          "type": "string",
          "description": "Project name from CLAUDE.md"
        },
        "snapshot": { "$ref": "#/$defs/snapshot" },
        "changelog": {
          "type": "array",
          "items": { "$ref": "#/$defs/changelogEntry" }
        }
      }
    },
    "snapshot": {
      "type": "object",
      "properties": {
        "insights_total": { "type": "integer", "minimum": 0 },
        "insights_verified": { "type": "integer", "minimum": 0 },
        "conflicts_pending": { "type": "integer", "minimum": 0 },
        "outputs_count": { "type": "integer", "minimum": 0 }
      }
    },
    "changelogEntry": {
      "type": "object",
      "required": ["version", "date", "description"],
      "properties": {
        "version": { "type": "string" },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "description": { "type": "string" }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "heading", "type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique section identifier for anchoring"
        },
        "heading": {
          "type": "string",
          "description": "Section heading (in output_language)"
        },
        "type": {
          "type": "string",
          "enum": ["text", "callout", "table", "module-list", "open-questions", "gap"]
        },
        "content": {
          "type": "string",
          "description": "Text content (for text, callout, gap types)"
        },
        "refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(IG|CF)-\\d+$" },
          "description": "Insight/conflict references"
        },
        "notes": {
          "type": "string",
          "description": "Speaker notes (presentation only)"
        },
        "headers": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Table column headers (table type)"
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": "Table rows (table type)"
        },
        "items": {
          "type": "array",
          "description": "List items (module-list, open-questions types)"
        }
      }
    },
    "moduleItem": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "status": { "type": "string" },
        "refs": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(IG|CF)-\\d+$" }
        },
        "implications": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["text"],
            "properties": {
              "text": { "type": "string" },
              "ref": { "type": "string", "pattern": "^(IG|CF)-\\d+$" }
            }
          }
        }
      }
    }
  }
}
