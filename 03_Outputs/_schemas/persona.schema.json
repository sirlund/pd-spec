{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "persona.schema.json",
  "description": "JSON Schema for PD-Spec Persona output data",
  "type": "object",
  "required": ["meta", "title", "personas"],
  "properties": {
    "meta": {
      "$ref": "base.schema.json#/$defs/meta",
      "properties": {
        "type": { "const": "persona" }
      }
    },
    "title": {
      "type": "string",
      "description": "Document title (in output_language)"
    },
    "personas": {
      "type": "array",
      "minItems": 3,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/persona" },
      "description": "User persona archetypes derived from verified insights"
    }
  },
  "$defs": {
    "refItem": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "description": "Description of the goal, frustration, context, or behavior"
        },
        "ref": {
          "type": "string",
          "pattern": "^(IG|CF)-\\d+$",
          "description": "Insight or conflict reference ID"
        }
      }
    },
    "persona": {
      "type": "object",
      "required": ["id", "name", "role", "quote", "goals", "frustrations", "context", "behaviors"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^P-\\d+$",
          "description": "Persona identifier (e.g. P-01)"
        },
        "name": {
          "type": "string",
          "description": "Realistic name (not stereotypical)"
        },
        "role": {
          "type": "string",
          "description": "Job title or role description"
        },
        "quote": {
          "type": "object",
          "required": ["text"],
          "properties": {
            "text": {
              "type": "string",
              "description": "Representative quote from a real source"
            },
            "ref": {
              "type": "string",
              "pattern": "^(IG|CF)-\\d+$",
              "description": "Source insight for the quote"
            }
          }
        },
        "goals": {
          "type": "array",
          "items": { "$ref": "#/$defs/refItem" },
          "description": "What this persona wants to achieve"
        },
        "frustrations": {
          "type": "array",
          "items": { "$ref": "#/$defs/refItem" },
          "description": "What blocks this persona"
        },
        "context": {
          "type": "array",
          "items": { "$ref": "#/$defs/refItem" },
          "description": "Work environment, tools, constraints"
        },
        "behaviors": {
          "type": "array",
          "items": { "$ref": "#/$defs/refItem" },
          "description": "How this persona currently works"
        }
      }
    }
  }
}
