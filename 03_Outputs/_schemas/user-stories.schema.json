{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "user-stories.schema.json",
  "description": "JSON Schema for PD-Spec User Stories output data (JTBD-framed)",
  "type": "object",
  "required": ["meta", "title", "modules"],
  "properties": {
    "meta": {
      "$ref": "base.schema.json#/$defs/meta",
      "properties": {
        "type": { "const": "user-stories" }
      }
    },
    "title": {
      "type": "string",
      "description": "Document title (in output_language)"
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/module" },
      "description": "Story groups organized by module or user flow"
    },
    "traceability": {
      "type": "array",
      "items": { "$ref": "#/$defs/traceRow" },
      "description": "Traceability matrix: Story -> Insights -> Sources"
    }
  },
  "$defs": {
    "module": {
      "type": "object",
      "required": ["id", "name", "stories"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Module identifier (e.g. mod-onboarding)"
        },
        "name": {
          "type": "string",
          "description": "Module or flow display name (in output_language)"
        },
        "stories": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/story" }
        }
      }
    },
    "story": {
      "type": "object",
      "required": ["id", "jtbd", "acceptance_criteria", "priority", "refs"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^US-\\d+$",
          "description": "Story identifier (e.g. US-01)"
        },
        "persona": {
          "type": "string",
          "description": "Persona reference (P-XX ID or descriptive label if no personas exist)"
        },
        "jtbd": {
          "type": "object",
          "required": ["situation", "motivation", "outcome"],
          "properties": {
            "situation": {
              "type": "string",
              "description": "When [situation] — the triggering context"
            },
            "motivation": {
              "type": "string",
              "description": "I want to [motivation] — the user action"
            },
            "outcome": {
              "type": "string",
              "description": "So I can [outcome] — the expected benefit"
            }
          },
          "description": "JTBD statement: When [situation], I want to [motivation], so I can [outcome]"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/criterion" },
          "description": "Acceptance criteria derived from SYSTEM_MAP design implications"
        },
        "priority": {
          "type": "string",
          "enum": ["High", "Medium", "Low"],
          "description": "Priority based on insight convergence and business weight"
        },
        "refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(IG|CF)-\\d+$"
          },
          "description": "Insight/conflict references backing this story"
        }
      }
    },
    "criterion": {
      "type": "object",
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "description": "Acceptance criterion statement"
        },
        "ref": {
          "type": "string",
          "pattern": "^(IG|CF)-\\d+$",
          "description": "SYSTEM_MAP entry or insight reference for this criterion"
        }
      }
    },
    "traceRow": {
      "type": "object",
      "required": ["story_id", "insights", "sources"],
      "properties": {
        "story_id": {
          "type": "string",
          "pattern": "^US-\\d+$"
        },
        "insights": {
          "type": "array",
          "items": { "type": "string", "pattern": "^(IG|CF)-\\d+$" }
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Source file names that back the referenced insights"
        }
      }
    }
  }
}
